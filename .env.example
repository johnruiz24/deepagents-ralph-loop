# AWS Configuration
AWS_PROFILE=<<YOUR_AWS_PROFILE>>
AWS_REGION=eu-central-1

# Bedrock Models (configure these for your AWS region and models)
ANTHROPIC_MODEL_OPUS=<<PUT_YOUR_BEDROCK_OPUS_MODEL_HERE>>
ANTHROPIC_MODEL_HAIKU=<<PUT_YOUR_BEDROCK_HAIKU_MODEL_HERE>>
ANTHROPIC_MODEL_SONNET=<<PUT_YOUR_BEDROCK_SONNET_MODEL_HERE>>

# API Keys
TAVILY_API_KEY=<<YOUR_TAVILY_API_KEY>>
ELEVENLABS_API_KEY=<<YOUR_ELEVENLABS_API_KEY>>
LANGCHAIN_API_KEY=<<YOUR_LANGSMITH_API_KEY>>

# LangSmith Tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=agent-newsletter

# Optional: GitHub Token (for repo analysis)
GITHUB_TOKEN=<<YOUR_GITHUB_TOKEN>>

# Quality Thresholds
RESEARCH_QUALITY_THRESHOLD=85
SOURCE_COUNT_THRESHOLD=5
READABILITY_THRESHOLD=60

# Article Constraints (NON-NEGOTIABLE)
MIN_ARTICLE_WORDS=2000
MAX_ARTICLE_WORDS=2500
TARGET_READING_MINUTES=10

# Video Constraints
VIDEO_DURATION_SECONDS=60
VIDEO_TOLERANCE_SECONDS=2

# Target Audience Configuration
TARGET_AUDIENCE=Leadership and Strategy Teams
