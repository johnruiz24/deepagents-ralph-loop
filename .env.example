# AWS Configuration
AWS_PROFILE=mll-dev
AWS_REGION=eu-central-1
ANTHROPIC_MODEL=eu.anthropic.claude-opus-4-5-20251101-v1:0
ANTHROPIC_SMALL_FAST_MODEL=eu.anthropic.claude-haiku-4-5-20251001-v1:0

# API Keys
TAVILY_API_KEY=your-tavily-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key
LANGCHAIN_API_KEY=your-langsmith-api-key

# LangSmith Tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=agent-newsletter

# Optional: GitHub Token (for repo analysis)
GITHUB_TOKEN=your-github-token

# Quality Thresholds
RESEARCH_QUALITY_THRESHOLD=85
SOURCE_COUNT_THRESHOLD=5
READABILITY_THRESHOLD=60

# Article Constraints (NON-NEGOTIABLE)
MIN_ARTICLE_WORDS=2000
MAX_ARTICLE_WORDS=2500
TARGET_READING_MINUTES=10

# Video Constraints
VIDEO_DURATION_SECONDS=60
VIDEO_TOLERANCE_SECONDS=2

# TUI Context (MANDATORY)
TUI_INVESTOR_URL=https://www.tuigroup.com/en/investors
